'use client';

import { useState } from 'react';

export default function AIMeetingMinutesSummarizer() {
  const [transcript, setTranscript] = useState('');
  const [minutes, setMinutes] = useState('');
  const [actionItems, setActionItems] = useState<string[]>([]);
  const [loading, setLoading] = useState(false);

  const generateMinutes = async () => {
    setLoading(true);
    // Simulate AI processing
    setTimeout(() => {
      setMinutes("Meeting Summary:\n• Discussed Q3 project timelines\n• Assigned new features to development team");
      setActionItems([
        "Follow up with design team by Friday",
        "Update roadmap in Task Workflow Layer",
        "Schedule review meeting next week"
      ]);
      setLoading(false);
    }, 1500);
  };

  return (
    <div className="p-8">
      <h2 className="text-4xl font-bold mb-8">AI Meeting Minutes Summarizer</h2>
      
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div>
          <h3 className="font-semibold mb-4">Paste Meeting Transcript</h3>
          <textarea 
            className="w-full h-96 p-6 border rounded-3xl" 
            placeholder="Paste transcript here..."
            value={transcript}
            onChange={(e) => setTranscript(e.target.value)}
          />
          <button 
            onClick={generateMinutes}
            disabled={loading || !transcript}
            className="mt-6 w-full py-5 bg-indigo-600 text-white rounded-2xl font-medium disabled:opacity-50"
          >
            {loading ? 'Summarizing...' : 'Generate Minutes & Action Items'}
          </button>
        </div>

        <div className="bg-gray-900 text-white p-8 rounded-3xl">
          <h3 className="font-semibold mb-6">AI Generated Output</h3>
          {minutes ? (
            <div className="space-y-8">
              <div className="whitespace-pre-wrap text-sm leading-relaxed">{minutes}</div>
              
              <div>
                <h4 className="font-medium mb-4 text-amber-400">Action Items</h4>
                <ul className="space-y-3">
                  {actionItems.map((item, i) => (
                    <li key={i} className="flex gap-3">
                      <span className="text-green-400">→</span> {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <p className="text-gray-500">Output will appear here...</p>
          )}
        </div>
      </div>
    </div>
  );
}